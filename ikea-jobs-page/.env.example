# הגדרות סביבה - עמוד משרות IKEA
# העתק קובץ זה ל-.env והגדר את הערכים המתאימים

# כתובת API למשרות מערכת אדם
# ברירת מחדל: /adam_all_orders_json.json
REACT_APP_ADAM_API_URL=https://your-api-domain.com/api/jobs

# מספר דקות בין ריענוני משרות אוטומטיים
# ברירת מחדל: 5 דקות
REACT_APP_REFRESH_MINUTES=5

# כתובת שרת Backend (אם קיים)
REACT_APP_BACKEND_URL=https://your-backend.com

# מצב פיתוח/ייצור
NODE_ENV=development
